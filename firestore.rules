rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Only the owner can read their full profile
      allow read: if request.auth != null && request.auth.uid == userId;

      // Owner can do anything to their own document
      allow write: if request.auth != null && request.auth.uid == userId;

      // Any authenticated user can credit another user's balance (for BytePay transfers).
      // Guard: only accountBalance may change, and only upward — prevents draining balances.
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['accountBalance'])
                    && request.resource.data.accountBalance >= resource.data.accountBalance;

      match /transactions/{transactionId} {
        // Owner can read/write their own transactions
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Any authenticated user can create a credit record in another user's transactions
        // (the incoming side of a BytePay transfer). Debit records are owner-only.
        allow create: if request.auth != null
                      && request.resource.data.type == 'credit';
      }
    }

    // Minimal public index so phone-number login can resolve to an email
    // WITHOUT exposing the rest of a user's profile (name, balance, PIN hash, etc).
    match /phoneIndex/{phone} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['email'])
                    && request.resource.data.email == request.auth.token.email;
      allow update, delete: if false;
    }

    // Public account-number → name/uid index for BytePay peer-to-peer lookup.
    // - get: any logged-in user can look up a single account number.
    // - list: disabled — nobody can enumerate all accounts.
    // - create/update: only the authenticated owner can write their own entry.
    // - delete: disabled.
    match /accountIndex/{accountNumber} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
  }
}
